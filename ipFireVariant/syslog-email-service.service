#!/bin/sh
# chkconfig: 345 95 05
# description: Syslog Email Forwarder (Pure Bash)

case "$1" in
  start)
    echo "Starting syslog email service..."
    /usr/local/bin/syslog-email-service.sh &
    echo $! > /var/run/syslog-email-service.pid
    ;;
  stop)
    echo "Stopping syslog email service..."
    kill $(cat /var/run/syslog-email-service.pid)
    rm -f /var/run/syslog-email-service.pid
    ;;
  restart)
    $0 stop
    sleep 1
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac
